# Copy to .env and adjust. Compose reads this directory’s .env automatically.

# AI Brain API auth (must match Frontend-nexus VITE_NEXUS_API_KEY when set)
NEXUS_API_KEY=dev-secret-key-replace-in-prod

# Host port published for nexus-ai-brain (container still listens on 8000 inside the network)
NEXUS_AI_BRAIN_HOST_PORT=8787

# Vault gateway → Brain on host (Docker Desktop). Use http://nexus_ai_brain:8000 from other Compose services.
NEXUS_MIRROR_TO_CLOUD=http://host.docker.internal:8787
