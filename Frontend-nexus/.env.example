# AI Brain origin (Vite dev proxy target when using /api). Docker default publish: 8787.
VITE_INSIGHTOS_API_URL=http://localhost:8787

# Required when Brain sets NEXUS_API_KEY — must match exactly (no quotes, no spaces).
VITE_NEXUS_API_KEY=

# Set to false to call the Brain URL directly from the browser in dev instead of the proxy.
# VITE_DEV_API_PROXY=false

# Sign-in: optional fixed passphrase (if unset, any phrase ≥4 chars is accepted for local demo).
# VITE_APP_LOGIN_SECRET=

# Skip login screen (dev only) — uses VITE_TENANT_ID below.
# VITE_SKIP_AUTH=false
VITE_TENANT_ID=TNT-DEMO01

# cloud | on_prem | hybrid
VITE_NEXUS_DEPLOYMENT=cloud
VITE_VAULT_GATEWAY_URL=http://localhost:8091

# Leave EMPTY unless Brain has NEXUS_RBAC_ENFORCE=true. A wrong role here causes 403 on RAG/analytics.
# If RBAC is on, use e.g. NEXUS_PRODUCT_MANAGER or NEXUS_TENANT_ADMIN.
VITE_NEXUS_RBAC_ROLE=
VITE_NEXUS_RBAC_TENANT=

# Browser OpenTelemetry OTLP HTTP (optional), e.g. http://localhost:4318/v1/traces
# VITE_OTEL_EXPORTER_OTLP_ENDPOINT=
