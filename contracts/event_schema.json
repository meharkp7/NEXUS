{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "InsightOS Event Schema",
  "type": "object",
  "required": ["tenant_id", "feature_id", "event_type", "timestamp", "session_id"],
  "properties": {
    "tenant_id": {
      "type": "string",
      "minLength": 1
    },
    "feature_id": {
      "type": "string",
      "minLength": 1
    },
    "event_type": {
      "type": "string",
      "enum": ["FEATURE_OPEN", "FEATURE_SUCCESS", "FEATURE_FAIL"]
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "session_id": {
      "type": "string"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  }
}